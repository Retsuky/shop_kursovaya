# Docker Compose: cp .env.example .env (файл в корне проекта)
# Локальный backend без Docker: cp backend/.env.example backend/.env

DB_USER=postgres
DB_NAME=shop_together
DB_HOST=postgres
DB_PORT=5432
DB_PASSWORD=true-password-in-true-env

JWT_SECRET=true-jwt-secret-in-true-env
ADMIN_EMAIL=admin@shop.local
ADMIN_PASSWORD=true-admin-password-in-true-env

BACKEND_PORT=3020
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3020/api
PUBLIC_BASE_URL=http://localhost:3020
